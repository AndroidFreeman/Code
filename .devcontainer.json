{
    "name": "Freeman-Pure-V7",
    // 1. 换成微软官方 Ubuntu 24.04 镜像，彻底甩掉 CS50 镜像
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd", // 你的补全神器
                "ms-vscode.cpptools",                   // C++ 调试基础
                "OBKoro1.korofileheader",               // 你的 FileHeader
                "catppuccin.catppuccin-vsc",            // 你的猫猫头主题
                "catppuccin.catppuccin-vsc-icons",      // 漂亮的图标
                "formulahendry.code-runner"             // 一键跑代码
            ],
            "settings": {
                // 2. 拿回被 CS50 禁用的功能
                "C_Cpp.autocomplete": "enabled",
                "editor.suggestOnTriggerCharacters": true,
                "editor.quickSuggestions": {
                    "other": "on",
                    "comments": "off",
                    "strings": "on"
                },
                "workbench.statusBar.visible": true,     // 让状态栏回来
                "breadcrumbs.enabled": true,             // 让面包屑导航回来
                "editor.minimap.enabled": true,          // 让缩略图回来
                
                // 3. 继承你的 Catppuccin 风格
                "workbench.colorTheme": "Catppuccin Macchiato",
                "workbench.iconTheme": "catppuccin-macchiato"
            }
        }
    },
    
    // 4. 自动安装环境，不用你进去手动敲
    "postCreateCommand": "sudo apt update && sudo apt install -y build-essential g++ gdb fastfetch"
}